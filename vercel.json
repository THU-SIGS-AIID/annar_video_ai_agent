{
  "version": 2,
  "name": "video-creator-agent",
  "builds": [
    {
      "src": "website/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/website/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/website/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/website/index.html"
    }
  ]
}
